@using WebIde.Model.Enums
@model WebIde.Frontend.Models.ProblemCreateModel
@{
    ViewData["Title"] = "CREATE PROBLEM";
}

@await Html.PartialAsync("_Sidebar")

<main class="lg:ml-64 pt-28 px-6 pb-24 min-h-screen">
    <div class="max-w-2xl mx-auto">

        <div class="mb-10">
            <h1 class="text-5xl font-black uppercase tracking-tighter mb-2"
                style="font-family:'Space Grotesk',sans-serif;">CREATE PROBLEM</h1>
            <div class="h-2 w-24 bg-primary border-2 border-black"></div>
            <nav class="text-xs font-bold uppercase mt-3" style="font-family:'Space Grotesk',sans-serif;">
                <a asp-controller="Home" asp-action="Index" class="text-primary hover:underline no-underline">HOME</a>
                <span class="mx-2 text-outline">/</span>
                <a asp-controller="Problem" asp-action="Index" class="text-primary hover:underline no-underline">PROBLEMS</a>
                <span class="mx-2 text-outline">/</span>
                <span class="text-on-surface-variant">CREATE</span>
            </nav>
        </div>

        <div class="border-4 border-black bg-white p-8 shadow-[6px_6px_0_0_rgba(0,0,0,1)]">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-5">
                    <label asp-for="Title" class="block text-xs font-bold uppercase tracking-widest mb-1"
                           style="font-family:'Space Grotesk',sans-serif;">TITLE *</label>
                    <input asp-for="Title"
                           class="brutalist-input w-full border-2 border-black px-3 py-2 bg-white text-black font-mono text-sm focus:outline-none focus:border-primary"
                           placeholder="e.g. Two Sum" />
                    <span asp-validation-for="Title" class="text-xs text-error font-bold mt-1 block"
                          style="font-family:'Space Grotesk',sans-serif;"></span>
                </div>

                <div class="mb-5">
                    <label asp-for="Description" class="block text-xs font-bold uppercase tracking-widest mb-1"
                           style="font-family:'Space Grotesk',sans-serif;">DESCRIPTION *</label>
                    <textarea asp-for="Description" rows="6"
                              class="brutalist-input w-full border-2 border-black px-3 py-2 bg-white text-black font-mono text-sm focus:outline-none focus:border-primary resize-none"
                              placeholder="Describe the problem..."></textarea>
                    <span asp-validation-for="Description" class="text-xs text-error font-bold mt-1 block"
                          style="font-family:'Space Grotesk',sans-serif;"></span>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-5">
                    <div>
                        <label asp-for="Difficulty" class="block text-xs font-bold uppercase tracking-widest mb-1"
                               style="font-family:'Space Grotesk',sans-serif;">DIFFICULTY *</label>
                        <select asp-for="Difficulty"
                                asp-items="Html.GetEnumSelectList<DifficultyLevel>()"
                                class="brutalist-input w-full border-2 border-black px-3 py-2 bg-white text-black font-mono text-sm focus:outline-none focus:border-primary">
                        </select>
                    </div>
                    <div>
                        <label asp-for="TimeLimitMs" class="block text-xs font-bold uppercase tracking-widest mb-1"
                               style="font-family:'Space Grotesk',sans-serif;">TIME LIMIT (ms) *</label>
                        <input asp-for="TimeLimitMs" type="number"
                               class="brutalist-input w-full border-2 border-black px-3 py-2 bg-white text-black font-mono text-sm focus:outline-none focus:border-primary" />
                        <span asp-validation-for="TimeLimitMs" class="text-xs text-error font-bold mt-1 block"
                              style="font-family:'Space Grotesk',sans-serif;"></span>
                    </div>
                    <div>
                        <label asp-for="MemoryLimitKb" class="block text-xs font-bold uppercase tracking-widest mb-1"
                               style="font-family:'Space Grotesk',sans-serif;">MEMORY LIMIT (KB) *</label>
                        <input asp-for="MemoryLimitKb" type="number"
                               class="brutalist-input w-full border-2 border-black px-3 py-2 bg-white text-black font-mono text-sm focus:outline-none focus:border-primary" />
                        <span asp-validation-for="MemoryLimitKb" class="text-xs text-error font-bold mt-1 block"
                              style="font-family:'Space Grotesk',sans-serif;"></span>
                    </div>
                </div>

                <div class="mb-5">
                    <label asp-for="AuthorUsername" class="block text-xs font-bold uppercase tracking-widest mb-1"
                           style="font-family:'Space Grotesk',sans-serif;">AUTHOR USERNAME *</label>
                    <input asp-for="AuthorUsername"
                           class="brutalist-input w-full border-2 border-black px-3 py-2 bg-white text-black font-mono text-sm focus:outline-none focus:border-primary" />
                    <span asp-validation-for="AuthorUsername" class="text-xs text-error font-bold mt-1 block"
                          style="font-family:'Space Grotesk',sans-serif;"></span>
                </div>

                <div class="mb-5">
                    @{
                        ViewData["FieldName"] = "CreatedAt";
                        ViewData["Label"]     = "CREATED AT";
                        ViewData["Value"]     = Model.CreatedAt as DateTime?;
                        ViewData["Required"]  = true;
                    }
                    @await Html.PartialAsync("_DatePicker")
                </div>

                <!-- Tags autocomplete -->
                <div class="mb-5">
                    @{
                        ViewData["FieldName"]   = "TagIds";
                        ViewData["Label"]       = "TAGS";
                        ViewData["SearchUrl"]   = "/Tag/Search";
                        ViewData["InitialText"] = "";
                        ViewData["InitialIds"]  = "";
                        ViewData["IsMulti"]     = true;
                        ViewData["Required"]    = false;
                    }
                    @await Html.PartialAsync("_AutocompleteDropdown")
                </div>

                <div class="flex gap-3 mt-6">
                    <button type="submit"
                            class="bg-primary text-white font-black uppercase px-6 py-2 border-2 border-black
                                   shadow-[4px_4px_0_0_rgba(0,0,0,1)] hover:translate-x-[-2px] hover:translate-y-[-2px]
                                   hover:shadow-[6px_6px_0_0_rgba(0,0,0,1)] transition-all text-sm"
                            style="font-family:'Space Grotesk',sans-serif;">CREATE</button>
                    <a asp-controller="Problem" asp-action="Index"
                       class="bg-white font-black uppercase px-6 py-2 border-2 border-black
                              shadow-[4px_4px_0_0_rgba(0,0,0,1)] hover:translate-x-[-2px] hover:translate-y-[-2px]
                              hover:shadow-[6px_6px_0_0_rgba(0,0,0,1)] transition-all text-sm no-underline"
                       style="font-family:'Space Grotesk',sans-serif;">CANCEL</a>
                </div>
            </form>
        </div>
    </div>
</main>
