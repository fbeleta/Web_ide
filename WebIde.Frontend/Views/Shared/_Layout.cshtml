<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — CODE_COMPILER</title>

    <!-- Google Fonts: Space Grotesk + Inter + Material Symbols -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <!-- Tailwind CSS (compiled — see tailwind/tailwind.config.js) -->
    <link rel="stylesheet" href="~/css/site.tailwind.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-background text-on-background" style="font-family: 'Inter', sans-serif;">

    <!-- ── Top Navigation ──────────────────────────────────────────── -->
    <nav class="fixed top-0 left-0 z-50 flex justify-between items-center w-full px-6 h-20
                bg-[#f6f6f6] border-b-4 border-black shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
        <div class="flex items-center gap-8">
            <a asp-controller="Home" asp-action="Index"
               class="text-2xl font-black italic tracking-tighter text-black no-underline"
               style="font-family: 'Space Grotesk', sans-serif;">CODE_COMPILER</a>
            <div class="hidden md:flex gap-1">
                <a asp-controller="Problem" asp-action="Index"
                   class="font-bold uppercase tracking-tighter text-black hover:bg-primary hover:text-white px-3 py-1 transition-none h-20 flex items-center"
                   style="font-family: 'Space Grotesk', sans-serif;">PROBLEMS</a>
                <a asp-controller="Leaderboard" asp-action="Index"
                   class="font-bold uppercase tracking-tighter text-black hover:bg-primary hover:text-white px-3 py-1 transition-none h-20 flex items-center"
                   style="font-family: 'Space Grotesk', sans-serif;">LEADERBOARD</a>
                <a asp-controller="Organization" asp-action="Index"
                   class="font-bold uppercase tracking-tighter text-black hover:bg-primary hover:text-white px-3 py-1 transition-none h-20 flex items-center"
                   style="font-family: 'Space Grotesk', sans-serif;">ORGS</a>
                <a asp-controller="Tag" asp-action="Index"
                   class="font-bold uppercase tracking-tighter text-black hover:bg-primary hover:text-white px-3 py-1 transition-none h-20 flex items-center"
                   style="font-family: 'Space Grotesk', sans-serif;">TAGS</a>
                <a asp-controller="Submission" asp-action="Index"
                   class="font-bold uppercase tracking-tighter text-black hover:bg-primary hover:text-white px-3 py-1 transition-none h-20 flex items-center"
                   style="font-family: 'Space Grotesk', sans-serif;">SUBMISSIONS</a>
            </div>
        </div>
        <div class="flex items-center gap-3">
            @if (User.Identity?.IsAuthenticated == true)
            {
                var avatarUrl   = User.FindFirst("webide:avatarUrl")?.Value ?? "";
                var displayName = User.FindFirst("webide:displayName")?.Value ?? User.Identity.Name ?? "USER";
                var initial     = displayName.Length > 0 ? displayName[0].ToString().ToUpper() : "?";

                @if (!string.IsNullOrEmpty(avatarUrl))
                {
                    <img src="@avatarUrl" alt="@displayName"
                         class="w-9 h-9 border-2 border-black object-cover" title="@displayName" />
                }
                else
                {
                    <div class="w-9 h-9 bg-black border-2 border-black flex items-center justify-center">
                        <span class="text-white font-black text-sm" style="font-family: 'Space Grotesk', sans-serif;">@initial</span>
                    </div>
                }

                <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            class="font-bold uppercase px-4 py-2 border-2 border-black text-sm
                                   shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]
                                   hover:bg-black hover:text-white transition-none cursor-pointer"
                            style="font-family: 'Space Grotesk', sans-serif;">LOGOUT</button>
                </form>
            }
            else
            {
                <a asp-controller="Auth" asp-action="Login"
                   class="bg-primary text-on-primary font-bold uppercase px-4 py-2 border-2 border-black
                          shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]
                          hover:translate-x-[-2px] hover:translate-y-[-2px] hover:shadow-[6px_6px_0px_0px_rgba(0,0,0,1)]
                          transition-all no-underline text-sm"
                   style="font-family: 'Space Grotesk', sans-serif;">GITHUB</a>
                <a asp-area="Identity" asp-page="/Account/Login"
                   class="font-bold uppercase px-4 py-2 border-2 border-black
                          shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]
                          hover:translate-x-[-2px] hover:translate-y-[-2px] hover:shadow-[6px_6px_0px_0px_rgba(0,0,0,1)]
                          transition-all no-underline text-sm bg-white"
                   style="font-family: 'Space Grotesk', sans-serif;">LOGIN</a>
            }
        </div>
    </nav>

    <!-- ── Page Content ─────────────────────────────────────────────── -->
    <div class="pt-20">
        @RenderBody()
    </div>

    <!-- ── Footer ───────────────────────────────────────────────────── -->
    <footer class="w-full bg-black border-t-4 border-black">
        <div class="w-full flex flex-col md:flex-row justify-between items-center px-10 py-6 gap-4">
            <span class="text-xs font-bold uppercase tracking-widest text-white"
                  style="font-family: 'Space Grotesk', sans-serif;">©2026_CODE_COMPILER_V.2.0</span>
            <div class="flex gap-8">
                <a asp-controller="Home" asp-action="Index"
                   class="text-xs font-bold uppercase tracking-widest text-white hover:text-[#32ff00] no-underline transition-none"
                   style="font-family: 'Space Grotesk', sans-serif;">HOME</a>
                <a asp-controller="Problem" asp-action="Index"
                   class="text-xs font-bold uppercase tracking-widest text-white hover:text-[#32ff00] no-underline transition-none"
                   style="font-family: 'Space Grotesk', sans-serif;">PROBLEMS</a>
                <a asp-controller="User" asp-action="Index"
                   class="text-xs font-bold uppercase tracking-widest text-white hover:text-[#32ff00] no-underline transition-none"
                   style="font-family: 'Space Grotesk', sans-serif;">USERS</a>
                <a asp-controller="Leaderboard" asp-action="Index"
                   class="text-xs font-bold uppercase tracking-widest text-white hover:text-[#32ff00] no-underline transition-none"
                   style="font-family: 'Space Grotesk', sans-serif;">LEADERBOARD</a>
            </div>
            <div class="flex gap-3">
                <div class="w-9 h-9 border-2 border-white flex items-center justify-center hover:bg-white hover:text-black cursor-pointer transition-none">
                    <span class="material-symbols-outlined text-sm text-white hover:text-black">terminal</span>
                </div>
                <div class="w-9 h-9 border-2 border-white flex items-center justify-center hover:bg-white hover:text-black cursor-pointer transition-none">
                    <span class="material-symbols-outlined text-sm text-white hover:text-black">code</span>
                </div>
            </div>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
