<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — CODE_COMPILER</title>

    <!-- Google Fonts: Space Grotesk + Inter + Material Symbols -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <!-- Tailwind CDN with Competitive Brutalism design tokens -->
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary":                  "#2752c7",
                        "on-primary":               "#f1f2ff",
                        "primary-container":        "#7f9bff",
                        "on-primary-container":     "#001c5f",
                        "secondary":                "#b60055",
                        "on-secondary":             "#ffeff1",
                        "secondary-container":      "#ffc1ce",
                        "on-secondary-container":   "#900042",
                        "tertiary":                 "#106b00",
                        "on-tertiary":              "#d3ffc0",
                        "tertiary-container":       "#32ff00",
                        "on-tertiary-container":    "#0c5c00",
                        "background":               "#f6f6f6",
                        "surface":                  "#f6f6f6",
                        "surface-bright":           "#f6f6f6",
                        "surface-container-lowest": "#ffffff",
                        "surface-container-low":    "#f1f1f1",
                        "surface-container":        "#e8e8e8",
                        "surface-container-high":   "#e2e2e2",
                        "surface-container-highest":"#dddddd",
                        "surface-variant":          "#dddddd",
                        "on-surface":               "#2f2f2f",
                        "on-background":            "#2f2f2f",
                        "on-surface-variant":       "#5b5b5b",
                        "outline":                  "#777777",
                        "outline-variant":          "#adadad",
                        "error":                    "#b41340",
                        "error-container":          "#f74b6d",
                        "on-error":                 "#ffefef",
                        "on-error-container":       "#510017",
                        "inverse-surface":          "#0e0e0e",
                    },
                    borderRadius: {
                        DEFAULT: "0px",
                        sm: "0px",
                        md: "0px",
                        lg: "0px",
                        xl: "0px",
                        "2xl": "0px",
                        full: "9999px",
                    },
                    fontFamily: {
                        headline: ["Space Grotesk", "sans-serif"],
                        body:     ["Inter", "sans-serif"],
                        label:    ["Space Grotesk", "sans-serif"],
                    },
                }
            }
        }
    </script>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <!-- Flatpickr datepicker -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <style>
        /* Brutalist Flatpickr overrides */
        .flatpickr-calendar { border: 2px solid #000 !important; border-radius: 0 !important; box-shadow: 4px 4px 0 0 rgba(0,0,0,1) !important; font-family: 'Space Grotesk', sans-serif !important; }
        .flatpickr-day.selected, .flatpickr-day.selected:hover { background: #2752c7 !important; border-color: #000 !important; border-radius: 0 !important; }
        .flatpickr-day:hover { background: #000 !important; color: #fff !important; border-radius: 0 !important; }
        .flatpickr-months { background: #000; color: #fff; }
        .flatpickr-month { color: #fff; fill: #fff; }
        .flatpickr-current-month { color: #fff; }
        .flatpickr-current-month .flatpickr-monthDropdown-months { color: #fff; background: #000; }
        .numInputWrapper span { border-color: #555; }
        .flatpickr-weekday { color: #fff; font-weight: 700; }
        .flatpickr-weekdays { background: #000; }
    </style>
</head>
<body class="bg-background text-on-background" style="font-family: 'Inter', sans-serif;">

    <!-- ── Top Navigation ──────────────────────────────────────────── -->
    <nav class="fixed top-0 left-0 z-50 flex justify-between items-center w-full px-6 h-20
                bg-[#f6f6f6] border-b-4 border-black shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
        <div class="flex items-center gap-8">
            <a asp-controller="Home" asp-action="Index"
               class="text-2xl font-black italic tracking-tighter text-black no-underline"
               style="font-family: 'Space Grotesk', sans-serif;">CODE_COMPILER</a>
            <div class="hidden md:flex gap-1">
                <a asp-controller="Problem" asp-action="Index"
                   class="font-bold uppercase tracking-tighter text-black hover:bg-primary hover:text-white px-3 py-1 transition-none h-20 flex items-center"
                   style="font-family: 'Space Grotesk', sans-serif;">PROBLEMS</a>
                <a asp-controller="Leaderboard" asp-action="Index"
                   class="font-bold uppercase tracking-tighter text-black hover:bg-primary hover:text-white px-3 py-1 transition-none h-20 flex items-center"
                   style="font-family: 'Space Grotesk', sans-serif;">LEADERBOARD</a>
                <a asp-controller="Organization" asp-action="Index"
                   class="font-bold uppercase tracking-tighter text-black hover:bg-primary hover:text-white px-3 py-1 transition-none h-20 flex items-center"
                   style="font-family: 'Space Grotesk', sans-serif;">ORGS</a>
                <a asp-controller="Tag" asp-action="Index"
                   class="font-bold uppercase tracking-tighter text-black hover:bg-primary hover:text-white px-3 py-1 transition-none h-20 flex items-center"
                   style="font-family: 'Space Grotesk', sans-serif;">TAGS</a>
                <a asp-controller="Submission" asp-action="Index"
                   class="font-bold uppercase tracking-tighter text-black hover:bg-primary hover:text-white px-3 py-1 transition-none h-20 flex items-center"
                   style="font-family: 'Space Grotesk', sans-serif;">SUBMISSIONS</a>
            </div>
        </div>
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-2xl p-2 border-2 border-transparent hover:border-black hover:bg-white cursor-pointer transition-none">terminal</span>
            <span class="material-symbols-outlined text-2xl p-2 border-2 border-transparent hover:border-black hover:bg-white cursor-pointer transition-none">notifications</span>
            <a asp-controller="Problem" asp-action="Index"
               class="bg-primary text-on-primary font-bold uppercase px-6 py-2 border-2 border-black
                      shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]
                      hover:translate-x-[-2px] hover:translate-y-[-2px] hover:shadow-[6px_6px_0px_0px_rgba(0,0,0,1)]
                      transition-all no-underline text-sm"
               style="font-family: 'Space Grotesk', sans-serif;">SOLVE</a>
        </div>
    </nav>

    <!-- ── Page Content ─────────────────────────────────────────────── -->
    <div class="pt-20">
        @RenderBody()
    </div>

    <!-- ── Footer ───────────────────────────────────────────────────── -->
    <footer class="w-full bg-black border-t-4 border-black">
        <div class="w-full flex flex-col md:flex-row justify-between items-center px-10 py-6 gap-4">
            <span class="text-xs font-bold uppercase tracking-widest text-white"
                  style="font-family: 'Space Grotesk', sans-serif;">©2026_CODE_COMPILER_V.2.0</span>
            <div class="flex gap-8">
                <a asp-controller="Home" asp-action="Index"
                   class="text-xs font-bold uppercase tracking-widest text-white hover:text-[#32ff00] no-underline transition-none"
                   style="font-family: 'Space Grotesk', sans-serif;">HOME</a>
                <a asp-controller="Problem" asp-action="Index"
                   class="text-xs font-bold uppercase tracking-widest text-white hover:text-[#32ff00] no-underline transition-none"
                   style="font-family: 'Space Grotesk', sans-serif;">PROBLEMS</a>
                <a asp-controller="User" asp-action="Index"
                   class="text-xs font-bold uppercase tracking-widest text-white hover:text-[#32ff00] no-underline transition-none"
                   style="font-family: 'Space Grotesk', sans-serif;">USERS</a>
                <a asp-controller="Leaderboard" asp-action="Index"
                   class="text-xs font-bold uppercase tracking-widest text-white hover:text-[#32ff00] no-underline transition-none"
                   style="font-family: 'Space Grotesk', sans-serif;">LEADERBOARD</a>
            </div>
            <div class="flex gap-3">
                <div class="w-9 h-9 border-2 border-white flex items-center justify-center hover:bg-white hover:text-black cursor-pointer transition-none">
                    <span class="material-symbols-outlined text-sm text-white hover:text-black">terminal</span>
                </div>
                <div class="w-9 h-9 border-2 border-white flex items-center justify-center hover:bg-white hover:text-black cursor-pointer transition-none">
                    <span class="material-symbols-outlined text-sm text-white hover:text-black">code</span>
                </div>
            </div>
        </div>
    </footer>

    <!-- jQuery + unobtrusive validation -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.21.0/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
    <!-- Flatpickr + HR locale -->
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/hr.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
