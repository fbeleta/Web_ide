@page
@model LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="flex items-center justify-center min-h-[70vh] px-4 py-12">
    <div class="brutal-card hard-shadow-lg w-full max-w-md">
        <h1 class="font-headline text-3xl font-black uppercase mb-2 tracking-tight">LOGIN_</h1>
        <p class="font-body text-sm text-gray-500 mb-8">Sign in to compete.</p>

        @if (Model.ExternalProviders.Any())
        {
            <form method="post" asp-page-handler="ExternalLogin" class="flex flex-col gap-3">
                @foreach (var provider in Model.ExternalProviders)
                {
                    <button type="submit" name="provider" value="@provider.Name"
                            class="bg-[#2752c7] text-[#f1f2ff] font-headline font-black uppercase text-sm px-6 py-4 hard-shadow hard-shadow-hover brutal-border tracking-widest w-full">
                        @provider.DisplayName Login
                    </button>
                }
            </form>
        }
        else
        {
            <p class="font-body text-sm text-red-600 font-bold">No login providers configured.</p>
        }
    </div>
</div>
