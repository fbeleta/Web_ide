@model List<WebIde.Model.Organization>
@{
    ViewData["Title"] = "ORGANIZATIONS";
}

@await Html.PartialAsync("_Sidebar")

<main class="lg:ml-64 pt-28 px-6 pb-24 min-h-screen">
    <div class="max-w-7xl mx-auto">

        <div class="mb-10">
            <h1 class="text-6xl font-black uppercase tracking-tighter mb-2"
                style="font-family: 'Space Grotesk', sans-serif;">ORGANIZATIONS</h1>
            <div class="h-2 w-32 bg-secondary border-2 border-black"></div>
            <nav class="text-xs font-bold uppercase mt-3" style="font-family: 'Space Grotesk', sans-serif;">
                <a asp-controller="Home" asp-action="Index" class="text-primary hover:underline no-underline">HOME</a>
                <span class="mx-2 text-outline">/</span>
                <span class="text-on-surface-variant">ORGANIZATIONS</span>
            </nav>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            @foreach (var org in Model)
            {
                <div class="border-4 border-black bg-white p-8 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] flex flex-col justify-between">
                    <div>
                        <div class="flex justify-between items-start mb-4">
                            <h3 class="text-3xl font-black uppercase tracking-tighter"
                                style="font-family: 'Space Grotesk', sans-serif;">@org.Name.ToUpper().Replace(" ", "_")</h3>
                            <span class="material-symbols-outlined text-4xl text-primary">group</span>
                        </div>
                        <p class="text-sm font-medium mb-6 leading-relaxed">@org.Description</p>
                        <div class="flex gap-4 mb-4">
                            <div class="border-2 border-black px-4 py-2">
                                <p class="text-xs font-bold uppercase text-outline"
                                   style="font-family: 'Space Grotesk', sans-serif;">MEMBERS</p>
                                <p class="text-2xl font-black" style="font-family: 'Space Grotesk', sans-serif;">@org.Members.Count</p>
                            </div>
                            <div class="border-2 border-black px-4 py-2">
                                <p class="text-xs font-bold uppercase text-outline"
                                   style="font-family: 'Space Grotesk', sans-serif;">SETS</p>
                                <p class="text-2xl font-black" style="font-family: 'Space Grotesk', sans-serif;">@org.ProblemSets.Count</p>
                            </div>
                        </div>
                    </div>
                    <a asp-controller="Organization" asp-action="Details" asp-route-id="@org.Id"
                       class="block text-center bg-black text-white font-black uppercase py-3 border-2 border-black
                              hover:bg-primary transition-none no-underline mt-4"
                       style="font-family: 'Space Grotesk', sans-serif;">VIEW_DETAILS →</a>
                </div>
            }
        </div>

    </div>
</main>
