# WebIde Environment Variables Template
# Copy to .env and fill in secrets before running.
# .env is gitignored — never commit it.
# Mode 600 on the server: chmod 600 /opt/webide/.env

# ── App / Worker ──────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
# Set to Development for local dev (relaxes cookie Secure policy, enables swagger etc.)
# ASPNETCORE_ENVIRONMENT=Development

PUBLIC_HOSTNAME=webide.example.com
# Used for OAuth redirect URI and HSTS. For local dev: localhost

LETSENCRYPT_EMAIL=ops@example.com
# Used for certbot ACME registration

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=webide
POSTGRES_DB=webide
POSTGRES_PASSWORD=
# Generate: openssl rand -base64 32

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=
# Generate: openssl rand -base64 32

# ── GitHub OAuth (Phase 1) ────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Create at: github.com/settings/developers → OAuth Apps
# Callback URL: https://${PUBLIC_HOSTNAME}/auth/github/callback

# ── Google OAuth (Lab 5) ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Create at: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
# Authorized redirect URI: https://${PUBLIC_HOSTNAME}/signin-google

# ── Seq log aggregation ───────────────────────────────────────────────────────
SEQ_FIRSTRUN_ADMINPASSWORD=
# One-time admin password set on first Seq startup. Change it via the Seq UI after.

SEQ_BASIC_AUTH_HTPASSWD=
# Generated with: htpasswd -B -n ops > nginx/htpasswd
# This is the content of the htpasswd file (mounted by nginx for /seq/ basic auth)
# On server: htpasswd -B -c /opt/webide/nginx/htpasswd ops

# ── Worker sandbox ────────────────────────────────────────────────────────────
WORKER__MAXCONCURRENTSANDBOXES=2
WORKER__SANDBOXMEMMB=512
WORKER__SANDBOXCPUS=0.9

# Sandbox image digests — set by sandbox.yml CI workflow (pinned by digest for reproducibility)
# For local dev: set to local tag names, e.g. webide-sandbox-python
SANDBOX_GCC_DIGEST=
SANDBOX_PYTHON_DIGEST=
SANDBOX_NODE_DIGEST=

# ── Backup / offsite ──────────────────────────────────────────────────────────
BACKUP_OFFSITE_TARGET=
# e.g. rsync://user@storagebox.hetzner.com/backups or s3://bucket/path
BACKUP_OFFSITE_PASSWORD=

# ── Deploy (used by docker-compose.yml image references) ─────────────────────
# IMAGE_TAG is set by the CI deploy pipeline (sha-{SHA}).
# Locally: leave unset to use :latest, or set to a specific tag.
IMAGE_TAG=latest

# ── Host UID/GID for worker bind mount ────────────────────────────────────────
# Worker container must run as the host deploy user to read/write /tmp/webide-src.
# On server: id -u deploy && id -g deploy
DEPLOY_UID=1000
DEPLOY_GID=1000
